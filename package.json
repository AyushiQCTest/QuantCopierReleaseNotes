{
  "name": "quantcopier-release-notes",
  "version": "1.0.0",
  "description": "QuantCopier Release Notes and Changelog - Hosted on Firebase",
  "scripts": {
    "dev": "next dev",
    "build": "npm run fetch:releases && next build",
    "start": "next start",
    "export": "next build && next export",
    "fetch:releases": "node scripts/fetch-github-releases.js",
    "generate:releases": "node scripts/generate-releases.js",
    "deploy": "npm run build && firebase deploy",
    "ci:build": "npm run fetch:releases && npm run build"
  },
  "dependencies": {
    "lucide-react": "^0.408.0",
    "next": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "postcss": "^8.5.14",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "zod": "^4.4.3"
  }
}
